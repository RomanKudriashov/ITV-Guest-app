# ---------------------------------------------------------------------------
# ITV-Guest-app — пример конфигурации. Скопируй в .env: cp .env.example .env
# ---------------------------------------------------------------------------

# --- Django ---------------------------------------------------------------
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*
# Базовый домен, от которого отрезается поддомен отеля.
# Гость приходит на crystal.guest.localhost -> subdomain = "crystal".
GUEST_APP_BASE_DOMAIN=guest.localhost
# Поддомены, которые НЕ являются отелями (платформенный уровень).
GUEST_APP_RESERVED_SUBDOMAINS=www,api,admin,platform,static,media

# --- PostgreSQL -----------------------------------------------------------
# Bootstrap-суперпользователь образа: инициализация и обслуживание.
# Приложение под ним НЕ работает — суперпользователь игнорирует RLS.
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=postgres
POSTGRES_DB=guestapp
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Роль приложения: подчиняется RLS (FORCE ROW LEVEL SECURITY).
POSTGRES_USER=guestapp
POSTGRES_PASSWORD=guestapp
# Платформенная роль: BYPASSRLS. Миграции, сид, платформенный уровень.
POSTGRES_PLATFORM_USER=guestapp_platform
POSTGRES_PLATFORM_PASSWORD=guestapp_platform

# --- Redis ----------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CHANNELS_REDIS_URL=redis://redis:6379/3

# --- MinIO ----------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:59000
MINIO_BUCKET=guest-media
MINIO_SECURE=0

# --- Auth -----------------------------------------------------------------
JWT_SECRET=dev-insecure-jwt-secret
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=14
GUEST_SESSION_TTL_HOURS=12

# --- Интеграционные швы (пока заглушки) -----------------------------------
PMS_ADAPTER=null
PAYMENT_ADAPTER=null

# --- Frontend -------------------------------------------------------------
VITE_API_PROXY=http://backend:8000

# --- Порты на хосте -------------------------------------------------------
# Внутри compose-сети сервисы всегда на своих стандартных портах. Наружу
# пробрасываем нестандартные, чтобы стенд не дрался за 5432/6379/9000 с
# другими проектами на той же машине.
POSTGRES_HOST_PORT=55432
REDIS_HOST_PORT=56379
MINIO_HOST_PORT=59000
MINIO_CONSOLE_HOST_PORT=59001
BACKEND_HOST_PORT=8010
FRONTEND_HOST_PORT=5183

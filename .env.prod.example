# ---------------------------------------------------------------------------
# Прод-конфигурация. НАСТОЯЩИЙ .env.prod живёт ТОЛЬКО на сервере и содержит
# сгенерированные секреты — в репозиторий не коммитится (см. .gitignore).
# Этот файл — шаблон с плейсхолдерами: секреты сгенерировать `openssl rand`.
#
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
# ---------------------------------------------------------------------------

# --- Домен (единственная переменная для смены заглушки на реальный домен) ---
# Заглушка на sslip.io: <ip>.sslip.io резолвится в этот IP без всякой настройки
# DNS, включая любые поддомены. Тенант-поддомены: <hotel>.app.<ip>.sslip.io.
APP_DOMAIN=app.147.45.245.172.sslip.io

# --- Django ----------------------------------------------------------------
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=__GENERATE__          # openssl rand -hex 32
JWT_SECRET=__GENERATE__                 # openssl rand -hex 32
# Пока без TLS (nginx на :80) — ссылки/QR формируем по http. При включении
# TLS с реальным доменом сменить на https.
GUEST_APP_PUBLIC_SCHEME=http
GUEST_APP_RESERVED_SUBDOMAINS=www,api,admin,platform,static,media

# --- PostgreSQL (порт наружу НЕ публикуется) -------------------------------
POSTGRES_DB=guestapp
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=__GENERATE__
POSTGRES_USER=guestapp
POSTGRES_PASSWORD=__GENERATE__
POSTGRES_PLATFORM_USER=guestapp_platform
POSTGRES_PLATFORM_PASSWORD=__GENERATE__

# --- MinIO (порт наружу НЕ публикуется; медиа отдаёт nginx) ----------------
MINIO_ROOT_USER=guestapp
MINIO_ROOT_PASSWORD=__GENERATE__
MINIO_BUCKET=guest-media
MINIO_SECURE=0
# Публичный адрес медиа = домен приложения; nginx проксирует /guest-media/.
MINIO_PUBLIC_ENDPOINT=app.147.45.245.172.sslip.io

# --- Сид ------------------------------------------------------------------
# Пусто = минимальный сид (только демо-отель, чтобы резолвился поддомен).
# Полный демо-контент приедет отдельным переносом данных.
SEED_ON_START=1
SEED_ARGS=
